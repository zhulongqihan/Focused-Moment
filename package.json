{
  "name": "focused-moment",
  "version": "1.5.1",
  "description": "Focused Moment focused desktop assistant built with Tauri, Rust, and SolidJS.",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "check": "tsc --noEmit",
    "tauri": "tauri",
    "export:debug": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File scripts/export-build-artifacts.ps1 -Profile debug",
    "export:release": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File scripts/export-build-artifacts.ps1 -Profile release",
    "export:exe": "pnpm export:release",
    "clean:artifacts": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File scripts/cleanup-build-artifacts.ps1",
    "release:github": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File scripts/publish-release.ps1 -Profile release -Latest",
    "release:ship": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File scripts/release-ship.ps1 -Latest",
    "package:debug": "pnpm tauri build --debug && pnpm export:debug",
    "package:release": "pnpm tauri build && pnpm export:release"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0"
  }
}
