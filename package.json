{
  "name": "focused-moment",
  "version": "0.7.0",
  "description": "Focused Moment focused desktop assistant built with Tauri, Rust, and SolidJS.",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "check": "tsc --noEmit",
    "tauri": "tauri",
    "export:exe": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File scripts/export-debug-exe.ps1",
    "package:debug": "pnpm tauri build --debug && pnpm export:exe"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0"
  }
}
