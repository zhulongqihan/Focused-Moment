{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focused Moment",
  "version": "1.1.1",
  "identifier": "com.zhulongqihan.focusedmoment",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Focused Moment",
        "width": 1280,
        "height": 820,
        "minWidth": 1120,
        "minHeight": 740,
        "center": true,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
